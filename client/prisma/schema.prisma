generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model VaultContract {
  id                  Int      @id @default(autoincrement())
  networkId           String   @map("network_id")
  vaultKeeperAddress  String   @unique @map("vault_keeper_address")
  vkprTokenAddress    String   @default("") @map("vkpr_token_address")
  ownerKey            String   @map("owner_key")
  name                String   @default("Untitled Vault")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("vault_contracts")
}
